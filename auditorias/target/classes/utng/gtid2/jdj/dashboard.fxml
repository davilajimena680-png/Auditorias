<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="utng.gtid2.dab.controlador.DashboardController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <top>
        <VBox spacing="10">

            <Label text="Dashboard de resultados y generación de reportes"
                   styleClass="titulo-seccion"/>

            <HBox spacing="10">

                <Label text="Auditoría:"/>

                <ComboBox fx:id="cmbAuditoria"
                          prefWidth="280"/>

                <Button text="Actualizar dashboard"
                        onAction="#actualizarDashboard"/>

                <Label text="Cumplimiento global ponderado:"/>

                <Label fx:id="lblPorcentajeGlobal"
                       styleClass="label-porcentaje"
                       text="--"/>

            </HBox>

        </VBox>
    </top>

    <center>

        <HBox fx:id="hboxGraficas"
              spacing="15">

            <PieChart fx:id="pieCumplimiento"
                      title="Distribución de cumplimiento"
                      HBox.hgrow="ALWAYS"/>

            <BarChart fx:id="barPorCategoria"
                      title="Cumplimiento por categoría (%)"
                      HBox.hgrow="ALWAYS">

                <xAxis>
                    <CategoryAxis label="Categoría"/>
                </xAxis>

                <yAxis>
                    <NumberAxis label="Cumplimiento (%)"
                                lowerBound="0"
                                upperBound="100"/>
                </yAxis>

            </BarChart>

        </HBox>

    </center>

    <bottom>

        <HBox spacing="10">

            <padding>
                <Insets top="10"/>
            </padding>

            <Button text="Generar reporte PDF"
                    onAction="#generarReportePDF"/>

            <Button text="Generar reporte Word"
                    onAction="#generarReporteWord"/>

            <Button text="Generar reporte Excel"
                    onAction="#generarReporteExcel"/>

        </HBox>

    </bottom>

</BorderPane>