<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.SplitPane?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="utng.gtid2.dab.controlador.HallazgosController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <top>
        <VBox spacing="10">

            <Label text="Hallazgos y plan de acción"
                   styleClass="titulo-seccion"/>

            <HBox spacing="10">

                <Label text="Auditoría:"/>

                <ComboBox fx:id="cmbAuditoria"
                          prefWidth="280"/>

                <Button text="Cargar"
                        onAction="#cargarDatosAuditoria"/>

            </HBox>

        </VBox>
    </top>

    <center>

        <SplitPane dividerPositions="0.45">

            <items>

                <VBox spacing="8">

                    <Label text="Evaluaciones capturadas (selecciona una para registrar un hallazgo)"/>

                    <TableView fx:id="tblEvaluaciones"
                               VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn fx:id="colCriterioEval"
                                         text="Criterio"
                                         prefWidth="260"/>

                            <TableColumn fx:id="colCumplimientoEval"
                                         text="Cumplimiento"
                                         prefWidth="110"/>

                        </columns>

                    </TableView>

                    <GridPane hgap="10" vgap="6">

                        <Label text="Tipo:"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <ChoiceBox fx:id="chkTipo"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                        <Label text="Riesgo:"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="2"/>

                        <ChoiceBox fx:id="chkRiesgo"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="3"/>

                        <Label text="Descripción:"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                        <TextArea fx:id="txtDescripcionHallazgo"
                                  GridPane.rowIndex="1"
                                  GridPane.columnIndex="1"
                                  GridPane.columnSpan="3"
                                  prefRowCount="2"/>

                    </GridPane>

                    <Button text="Registrar hallazgo"
                            onAction="#registrarHallazgo"/>

                </VBox>

                <VBox spacing="8">

                    <Label text="Hallazgos registrados (selecciona uno para asignar plan de acción)"/>

                    <TableView fx:id="tblHallazgos"
                               VBox.vgrow="ALWAYS">

                        <columns>

                            <TableColumn fx:id="colTipoHallazgo"
                                         text="Tipo"
                                         prefWidth="140"/>

                            <TableColumn fx:id="colRiesgoHallazgo"
                                         text="Riesgo"
                                         prefWidth="80"/>

                            <TableColumn fx:id="colDescripcionHallazgo"
                                         text="Descripción"
                                         prefWidth="260"/>

                        </columns>

                    </TableView>

                    <GridPane hgap="10" vgap="6">

                        <Label text="Responsable:"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="0"/>

                        <TextField fx:id="txtResponsable"
                                   GridPane.rowIndex="0"
                                   GridPane.columnIndex="1"/>

                        <Label text="Fecha compromiso:"
                               GridPane.rowIndex="0"
                               GridPane.columnIndex="2"/>

                        <DatePicker fx:id="dpFechaCompromiso"
                                    GridPane.rowIndex="0"
                                    GridPane.columnIndex="3"/>

                        <Label text="Estatus:"
                               GridPane.rowIndex="1"
                               GridPane.columnIndex="0"/>

                        <ChoiceBox fx:id="chkEstatusPlan"
                                   GridPane.rowIndex="1"
                                   GridPane.columnIndex="1"/>

                    </GridPane>

                    <Button text="Guardar plan de acción"
                            onAction="#guardarPlanAccion"/>

                </VBox>

            </items>

        </SplitPane>

    </center>

</BorderPane>