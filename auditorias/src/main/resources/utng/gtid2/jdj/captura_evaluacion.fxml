<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="utng.gtid2.dab.controlador.CapturaEvaluacionController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <top>
        <VBox spacing="10">

            <Label text="Captura de evaluación por criterio"
                   styleClass="titulo-seccion"/>

            <HBox spacing="10">

                <Label text="Auditoría activa:"/>

                <ComboBox fx:id="cmbAuditoria"
                          prefWidth="260"/>

                <Label text="Categoría:"/>

                <ComboBox fx:id="cmbCategoria"
                          prefWidth="220"/>

                <Button text="Cargar criterios"
                        onAction="#cargarCriterios"/>

            </HBox>

        </VBox>
    </top>

    <center>
        <TableView fx:id="tblCriterios"
                   editable="true">

            <columns>

                <TableColumn fx:id="colDescripcion"
                             text="Criterio"
                             prefWidth="380"/>

                <TableColumn fx:id="colPeso"
                             text="Peso"
                             prefWidth="60"/>

                <TableColumn fx:id="colCumplimiento"
                             text="Cumplimiento"
                             prefWidth="150"
                             editable="true"/>

                <TableColumn fx:id="colObservaciones"
                             text="Observaciones"
                             prefWidth="300"
                             editable="true"/>

            </columns>

        </TableView>
    </center>

    <bottom>
        <HBox spacing="10">

            <padding>
                <Insets top="10"/>
            </padding>

            <Button text="Guardar evaluación de esta categoría"
                    onAction="#guardarEvaluacion"/>

        </HBox>
    </bottom>

</BorderPane>